            match = re.search(r'connectivity\s*=\s*(\[.*\])', content)
            if match:
                connectivity_str = match.group(1)
                connectivity_initial = eval(connectivity_str)
                Qasmmap = True
                sys.argv.remove(config_file)
                sys.argv.remove('-qpu-config')


        accidx = sys.argv.index('-qpu')
        accName = sys.argv[accidx+1]
        if accName not in {'qasm-backend','tianyan','originquantum','qir-runner'}:
                print('Invalid compile command: Not support backend:', accName)
                print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                exit(1)

        sys.argv.remove(accName)
        sys.argv.remove('-qpu')

        sys.argv += ['-D__internal__qllvm__compile__backend=\"'+accName+'\"']
        sHandlerArgs = ['-Xclang', '-plugin-arg-qllvm-args', '-Xclang', '-qpu', '-Xclang', '-plugin-arg-qllvm-args', '-Xclang', accName]
    else:
        accName = 'qpp'
        sys.argv += ['-D__internal__qllvm__compile__backend=\"'+accName+'\"']
        sHandlerArgs = ['-Xclang', '-plugin-arg-qllvm-args', '-Xclang', '-qpu', '-Xclang', '-plugin-arg-qllvm-args', '-Xclang', accName]

    # Get the shots if necessary
    Shots = 0
    if '-shots' in sys.argv[1:]:
        sidx = sys.argv.index('-shots')
        Shots = sys.argv[sidx+1]
        sys.argv.remove(Shots)
        sys.argv.remove('-shots')
