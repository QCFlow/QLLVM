        if qrtName != 'nisq':
            print('Invalid compile command: Currently -qrt only support nisq')
            print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
            exit(1)
        sys.argv.remove(qrtName)
        sys.argv.remove('-qrt')
        sys.argv += ['-D__internal__qllvm__compile__qrt__mode=\"'+qrtName+'\"']   
        if qrtName == 'ftqc': 
            sys.argv += ['-D_QLLVM_FTQC_RUNTIME']
    

    # Get the filename we are compiling or the object file
    filename = ''
    fileType = ''
        # Phase 1: Hybrid compilation with qir-runner as simulator
    def compile_hybrid_qir_runner(cpp_files, qasm_files, output_exe=None):
        """Compile C++ + QASM to exe that spawns qir-runner for quantum simulation."""
        # Use g++ for C++/stub when available (~10x faster than clang on Debug builds)
        _shutil = __import__('shutil')
        cxx_compiler = _shutil.which('g++') or _shutil.which('gcc') or compiler
        llvm_bin_path = str(pathlib.Path(compiler).parent)
        qllvm_tool = '@CMAKE_INSTALL_PREFIX@/bin/qllvm-compile'
        build_base = None
        if not os.path.exists(qllvm_tool):
            for base in [os.getcwd(), os.path.dirname(os.getcwd())]:
                build_tool = os.path.join(base, 'build', 'bin', 'qllvm-compile')
                if os.path.exists(build_tool):
                    qllvm_tool = build_tool
                    build_base = os.path.join(base, 'build')
                    break
        run_env = os.environ.copy()
        if build_base:
            lib_paths = [os.path.join(build_base, 'lib'), os.path.join(build_base, 'mlir', 'parsers', 'qiskit'),
                        os.path.join(build_base, 'mlir', 'parsers', 'qasm3'), os.path.join(build_base, 'mlir', 'dialect')]
            run_env['LD_LIBRARY_PATH'] = ':'.join(lib_paths) + (':' + run_env.get('LD_LIBRARY_PATH', ''))
        work_dir = os.getcwd()
        _qir_rt_inc = ['-I', '@CMAKE_INSTALL_PREFIX@/include/qllvm', '-I', '@QLLVM_QIR_RUNTIME_INCLUDE@']
        opt_level = '-O1' if '-O1' in sys.argv[1:] else '-O0'
        shots = 1024
        if '-shots' in sys.argv[1:]:
            idx = sys.argv.index('-shots') + 1
            if idx < len(sys.argv):
                try:
                    shots = int(sys.argv[idx])
                except ValueError:
                    pass

        # 1. Compile each QASM to .bc (qir-runner backend)
        bc_files = []
        for qasm_file in qasm_files:
            base = os.path.splitext(os.path.basename(qasm_file))[0]
            bc_path = os.path.join(work_dir, base + '.bc')
            preproc_cmd = [cxx_compiler, '-x', 'c++', '-E', '-P', qasm_file]
            try:
                result = subprocess.check_output(preproc_cmd).decode('ascii')
            except Exception:
                result = open(qasm_file, 'r').read()
            if os.path.splitext(qasm_file)[1] == '.qasm':
                filter_lines = [line for line in result.split('\n')
                    if 'OPENQASM' not in line and len(line) > 0]
                text = 'OPENQASM 3;\n' + '\n'.join(filter_lines)
            else:
                text = result
            tmp_qasm = '__tmp_hybrid_' + base + '.qasm'
            with open(tmp_qasm, 'w') as f:
                f.write(text)
            cmd = [qllvm_tool, tmp_qasm, '-qrt', 'nisq', '-qpu', 'qir-runner', opt_level,
                   '-emit-backend=qir-runner', '-output-path=' + bc_path]
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True, env=run_env)
            os.remove(tmp_qasm)
            bc_files.append((base, bc_path))

        # 2. Generate kernel stubs that call qir_runner_execute
        stub_cpp = os.path.join(work_dir, '__qir_runner_kernels.cpp')
        with open(stub_cpp, 'w') as f:
            f.write('/* Auto-generated kernel stubs for qir-runner hybrid */\n')
            f.write('extern "C" void qir_runner_execute(const char* kernel_name, int shots);\n\n')
            for base, _ in bc_files:
                f.write('extern "C" void __internal_mlir_{}() {{\n'.format(base))
                f.write('  qir_runner_execute("{}", 0);\n'.format(base))  # 0 = use default from argv
                f.write('}\n\n')
        stub_o = os.path.join(work_dir, '__qir_runner_kernels.o')

        # 3. Compile C++ sources (use g++ when available for ~10x faster compile)
        cpp_objs = []
        for cpp_file in cpp_files:
            base = os.path.splitext(os.path.basename(cpp_file))[0]
            o_path = os.path.join(work_dir, base + '_classical.o')
            cmd = [cxx_compiler, '-c', '-std=c++17'] + _qir_rt_inc + ['-o', o_path, cpp_file]
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True)
            cpp_objs.append(o_path)

        # 4. Compile kernel stubs
        cmd = [cxx_compiler, '-c', '-std=c++17'] + _qir_rt_inc + ['-o', stub_o, stub_cpp]
        if verbose:
            info(' '.join(cmd))
        subprocess.run(cmd, check=True)

        # 5. Link
        exe_name = output_exe if output_exe else 'hybrid_app'
        lib_dir = '@CMAKE_INSTALL_PREFIX@/lib'
        runtime_a = None
        for cand in [
            os.path.join(build_base or '', 'mlir', 'qir_runner_runtime', 'libqir-runner-runtime.a'),
            os.path.join(lib_dir, 'libqir-runner-runtime.a'),
            os.path.join(os.path.expanduser('~'), '.qllvm', 'lib', 'libqir-runner-runtime.a'),
        ]:
            if cand and os.path.exists(cand):
                runtime_a = cand
                break
        if not runtime_a:
            raise FileNotFoundError('libqir-runner-runtime.a not found. Build qllvm with ninja install.')
        link_cmd = [cxx_compiler, '-o', exe_name] + cpp_objs + [stub_o, runtime_a]
        if verbose:
            info(' '.join(link_cmd))
        subprocess.run(link_cmd, check=True)

        # 6. Pass -shots via wrapper or document; .bc files stay in cwd
        for f in [stub_cpp, stub_o] + cpp_objs:
            try:
                os.remove(f)
            except OSError:
                pass
        if verbose:
            info('Hybrid (qir-runner) executable: {}. Run with: {} -shots {}'.format(exe_name, exe_name, shots))
        return exe_name

    # Phase 1: C++ + CUDA + QASM hybrid compilation (qir-runner for quantum)
    def compile_hybrid_cuda_quantum(cpp_files, cu_files, qasm_files, output_exe=None):
        """Compile C++ + CUDA + QASM to exe: CUDA kernels + qir-runner for quantum."""
        _shutil = __import__('shutil')
        cxx_compiler = _shutil.which('g++') or _shutil.which('gcc') or compiler
        llvm_bin_path = str(pathlib.Path(compiler).parent)
        qllvm_tool = '@CMAKE_INSTALL_PREFIX@/bin/qllvm-compile'
        build_base = None
        if not os.path.exists(qllvm_tool):
            for base in [os.getcwd(), os.path.dirname(os.getcwd())]:
                build_tool = os.path.join(base, 'build', 'bin', 'qllvm-compile')
                if os.path.exists(build_tool):
                    qllvm_tool = build_tool
                    build_base = os.path.join(base, 'build')
                    break
        run_env = os.environ.copy()
        if build_base:
            lib_paths = [os.path.join(build_base, 'lib'), os.path.join(build_base, 'mlir', 'parsers', 'qiskit'),
                        os.path.join(build_base, 'mlir', 'parsers', 'qasm3'), os.path.join(build_base, 'mlir', 'dialect')]
            run_env['LD_LIBRARY_PATH'] = ':'.join(lib_paths) + (':' + run_env.get('LD_LIBRARY_PATH', ''))
        work_dir = os.getcwd()
        _qir_rt_inc_cuda = ['-I', '@CMAKE_INSTALL_PREFIX@/include/qllvm', '-I', '@QLLVM_QIR_RUNTIME_INCLUDE@']
        opt_level = '-O1' if '-O1' in sys.argv[1:] else '-O0'

        # Parse CUDA options
        cuda_arch = 'sm_75'
        if '-cuda-arch' in sys.argv[1:]:
            idx = sys.argv.index('-cuda-arch') + 1
            if idx < len(sys.argv):
                cuda_arch = sys.argv[idx]
        cuda_path = os.environ.get('CUDA_PATH', '')
        if '-cuda-path' in sys.argv[1:]:
            idx = sys.argv.index('-cuda-path') + 1
            if idx < len(sys.argv):
                cuda_path = sys.argv[idx]
        if not cuda_path:
            cuda_path = '/usr/local/cuda'
        # 未显式指定时：apt 安装的 CUDA 布局与 Clang 不符，优先用 install_cuda_apt.sh 创建的兼容层
        apt_compat = os.path.join(os.path.expanduser('~'), '.qllvm', 'cuda-apt-compat')
        if not cuda_path or cuda_path == '/usr' or not os.path.isdir(cuda_path):
            if os.path.isdir(apt_compat):
                cuda_path = apt_compat
        if not os.path.isdir(cuda_path):
            nvcc = _shutil.which('nvcc')
            if nvcc:
                cuda_path = os.path.dirname(os.path.dirname(nvcc))
            if not os.path.isdir(cuda_path):
                raise FileNotFoundError('CUDA path not found: {}. Set CUDA_PATH or use -cuda-path.'.format(cuda_path))

        # 1. Compile .cu -> .o (优先 nvcc，clang -x cuda 在 apt 环境下易有 include 问题)
        cu_objs = []
        nvcc_path = _shutil.which('nvcc')
        for cu_file in cu_files:
            base = os.path.splitext(os.path.basename(cu_file))[0]
            o_path = os.path.join(work_dir, base + '_cuda.o')
            if nvcc_path:
                cmd = [nvcc_path, '-x', 'cu', '-c', cu_file, '-o', o_path, '-arch=' + cuda_arch]
            else:
                cmd = [compiler, '-x', 'cuda', '-c', cu_file, '-o', o_path,
                       '--cuda-gpu-arch=' + cuda_arch, '--cuda-path=' + cuda_path, '-I/usr/include']
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True)
            cu_objs.append(o_path)

        # 2. Compile .cpp -> .o
        cpp_objs = []
        for cpp_file in cpp_files:
            base = os.path.splitext(os.path.basename(cpp_file))[0]
            o_path = os.path.join(work_dir, base + '_classical.o')
            cmd = [cxx_compiler, '-c', '-std=c++17'] + _qir_rt_inc_cuda + ['-o', o_path, cpp_file]
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True)
            cpp_objs.append(o_path)

        # 3. Compile QASM -> .bc and generate stubs (qir-runner path)
        bc_files = []
        for qasm_file in qasm_files:
            base = os.path.splitext(os.path.basename(qasm_file))[0]
            bc_path = os.path.join(work_dir, base + '.bc')
            preproc_cmd = [cxx_compiler, '-x', 'c++', '-E', '-P', qasm_file]
            try:
                result = subprocess.check_output(preproc_cmd).decode('ascii')
            except Exception:
                result = open(qasm_file, 'r').read()
            if os.path.splitext(qasm_file)[1] == '.qasm':
                filter_lines = [line for line in result.split('\n')
                    if 'OPENQASM' not in line and len(line) > 0]
                text = 'OPENQASM 3;\n' + '\n'.join(filter_lines)
            else:
                text = result
            tmp_qasm = '__tmp_hybrid_' + base + '.qasm'
            with open(tmp_qasm, 'w') as f:
                f.write(text)
            cmd = [qllvm_tool, tmp_qasm, '-qrt', 'nisq', '-qpu', 'qir-runner', opt_level,
                   '-emit-backend=qir-runner', '-output-path=' + bc_path]
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True, env=run_env)
            os.remove(tmp_qasm)
            bc_files.append((base, bc_path))

        # 4. Generate kernel stubs
        stub_cpp = os.path.join(work_dir, '__qir_runner_kernels.cpp')
        with open(stub_cpp, 'w') as f:
            f.write('/* Auto-generated kernel stubs for CUDA + qir-runner hybrid */\n')
            f.write('extern "C" void qir_runner_execute(const char* kernel_name, int shots);\n\n')
            for base, _ in bc_files:
                f.write('extern "C" void __internal_mlir_{}() {{\n'.format(base))
                f.write('  qir_runner_execute("{}", 0);\n'.format(base))
                f.write('}\n\n')
        stub_o = os.path.join(work_dir, '__qir_runner_kernels.o')
        cmd = [cxx_compiler, '-c', '-std=c++17'] + _qir_rt_inc_cuda + ['-o', stub_o, stub_cpp]
        if verbose:
            info(' '.join(cmd))
        subprocess.run(cmd, check=True)

        # 5. Link
        exe_name = output_exe if output_exe else 'hybrid_app'
        lib_dir = '@CMAKE_INSTALL_PREFIX@/lib'
        runtime_a = None
        for cand in [
            os.path.join(build_base or '', 'mlir', 'qir_runner_runtime', 'libqir-runner-runtime.a'),
            os.path.join(lib_dir, 'libqir-runner-runtime.a'),
            os.path.join(os.path.expanduser('~'), '.qllvm', 'lib', 'libqir-runner-runtime.a'),
        ]:
            if cand and os.path.exists(cand):
                runtime_a = cand
                break
        if not runtime_a:
            raise FileNotFoundError('libqir-runner-runtime.a not found. Build qllvm with ninja install.')
        cuda_lib_dir = os.path.join(cuda_path, 'lib64')
        obj_inputs = cpp_objs + cu_objs + [stub_o, runtime_a]
        if nvcc_path:
            link_cmd = ([nvcc_path, '-o', exe_name, '-arch=' + cuda_arch] + obj_inputs +
                        ['-L' + cuda_lib_dir, '-lcudart', '-lcuda', '-ldl', '-lrt', '-lpthread',
                         '-Xcompiler', '-std=c++17'])
        else:
            link_cmd = ([cxx_compiler, '-o', exe_name] + obj_inputs +
                        ['-L' + cuda_lib_dir, '-lcudart', '-lcuda', '-ldl', '-lrt', '-lpthread'])
        if verbose:
            info(' '.join(link_cmd))
        subprocess.run(link_cmd, check=True)

        # 6. Cleanup temp files
        for f in [stub_cpp, stub_o] + cpp_objs + cu_objs:
            try:
                os.remove(f)
            except OSError:
                pass
        if verbose:
            info('Hybrid (C+++CUDA+qir-runner) executable: {}. Run with: {} -shots <n>'.format(exe_name, exe_name))
        return exe_name

    # Phase 1: Hybrid compilation - classical C++ + quantum QASM
    def compile_hybrid(cpp_files, qasm_files, output_exe=None):
        """Compile mixed C++ and QASM sources to a single executable (LLVM协同)."""
        llvm_bin_path = str(pathlib.Path(compiler).parent)
        qllvm_tool = '@CMAKE_INSTALL_PREFIX@/bin/qllvm-compile'
        build_base = None
        if not os.path.exists(qllvm_tool):
            # Fallback for dev/debug: try cwd/build/bin or cwd/../build/bin
            for base in [os.getcwd(), os.path.dirname(os.getcwd())]:
                build_tool = os.path.join(base, 'build', 'bin', 'qllvm-compile')
                if os.path.exists(build_tool):
                    qllvm_tool = build_tool
                    build_base = os.path.join(base, 'build')
                    break
        # For build dir: add lib paths so qllvm-compile finds its shared libs
        run_env = os.environ.copy()
        if build_base:
            lib_paths = [os.path.join(build_base, 'lib'), os.path.join(build_base, 'mlir', 'parsers', 'qiskit'),
                        os.path.join(build_base, 'mlir', 'parsers', 'qasm3'), os.path.join(build_base, 'mlir', 'dialect')]
            run_env['LD_LIBRARY_PATH'] = ':'.join(lib_paths) + (':' + run_env.get('LD_LIBRARY_PATH', ''))
        work_dir = os.getcwd()
        ll_files = []
        bc_files = []
        opt_level = '-O1' if '-O1' in sys.argv[1:] else '-O0'

        # 1. Compile each QASM to LLVM IR (no entry point - kernel only)
        for qasm_file in qasm_files:
            base = os.path.splitext(os.path.basename(qasm_file))[0]
            ll_path = os.path.join(work_dir, base + '_qir.ll')
            # Preprocess QASM (handle includes)
            preproc_cmd = [compiler, '-x', 'c++', '-E', '-P', qasm_file]
            if verbose:
                info(' '.join(preproc_cmd))
            try:
                result = subprocess.check_output(preproc_cmd).decode('ascii')
            except Exception:
                result = open(qasm_file, 'r').read()
            if os.path.splitext(qasm_file)[1] == '.qasm':
                filter_lines = [line for line in result.split('\n')
                    if 'OPENQASM' not in line and len(line) > 0]
                text = 'OPENQASM 3;\n' + '\n'.join(filter_lines)
            else:
                text = result
            tmp_qasm = '__tmp_hybrid_' + base + '.qasm'
            with open(tmp_qasm, 'w') as f:
                f.write(text)
            qrt_val = 'nisq'
            if '-qrt' in sys.argv[1:]:
                qrt_val = sys.argv[sys.argv.index('-qrt') + 1]
            cmd = [qllvm_tool, tmp_qasm, '-no-entrypoint', '-internal-func-name', base,
                   '-output-ll', ll_path, opt_level, '-qrt', qrt_val]
            if '-qpu' in sys.argv[1:]:
                idx = sys.argv.index('-qpu')
                cmd.extend(['-qpu', sys.argv[idx+1]])
            if '-basicgate' in str(sys.argv):
                for a in sys.argv[1:]:
                    if '-basicgate' in a:
                        cmd.append(a)
                        break
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True, env=run_env)
            os.remove(tmp_qasm)
            ll_files.append(ll_path)

        # 2. Compile each C++ to LLVM IR
        for cpp_file in cpp_files:
            base = os.path.splitext(os.path.basename(cpp_file))[0]
            ll_path = os.path.join(work_dir, base + '_classical.ll')
            cmd = [compiler, '-S', '-emit-llvm', '-std=c++17', '-o', ll_path, cpp_file]
            if verbose:
                info(' '.join(cmd))
            subprocess.run(cmd, check=True)
            ll_files.append(ll_path)

        # 3. Convert .ll to .bc and link
        for ll_path in ll_files:
            bc_path = ll_path.replace('.ll', '.bc')
            as_cmd = [llvm_bin_path + '/llvm-as', ll_path, '-o', bc_path]
            if verbose:
                info(' '.join(as_cmd))
            subprocess.run(as_cmd, check=True)
            bc_files.append(bc_path)

        merged_bc = os.path.join(work_dir, '__hybrid_merged.bc')
        link_cmd = [llvm_bin_path + '/llvm-link', '-o', merged_bc] + bc_files
        if verbose:
            info(' '.join(link_cmd))
        subprocess.run(link_cmd, check=True)

        # 4. Compile to object
        merged_o = os.path.join(work_dir, '__hybrid_merged.o')
        llc_cmd = [llvm_bin_path + '/llc', '-filetype=obj', merged_bc, '-o', merged_o]
        if verbose:
            info(' '.join(llc_cmd))
        subprocess.run(llc_cmd, check=True)

        # 5. Link to executable
        exe_name = output_exe if output_exe else 'hybrid_app'
        lib_dir = '@CMAKE_INSTALL_PREFIX@/lib'
        if build_base:
            stub_path = os.path.join(build_base, 'mlir', 'qir_qrt_stub')
            if os.path.exists(os.path.join(stub_path, 'libqir-qrt-stub.so')) or \
               os.path.exists(os.path.join(stub_path, 'libqir-qrt-stub.dylib')):
                lib_dir = stub_path
        hybrid_libs = ['-rdynamic', '-Wl,-rpath,' + lib_dir + ':@LLVM_INSTALL_PREFIX@/lib',
                      '-L', lib_dir, '-lpthread']
        if os.path.exists(os.path.join(lib_dir, 'libqir-qrt-stub.so')) or \
             os.path.exists(os.path.join(lib_dir, 'libqir-qrt-stub.dylib')):
            hybrid_libs += ['-lqir-qrt-stub']
        else:
            raise FileNotFoundError(
                'libqir-qrt-stub not found under ' + lib_dir + '. Run cmake install.')
        link_cmd = [compiler, merged_o, '-o', exe_name] + hybrid_libs
        if verbose:
            info(' '.join(link_cmd))
        subprocess.run(link_cmd, check=True)

        # Cleanup intermediates
        for f in ll_files + bc_files:
            try:
                os.remove(f)
            except OSError:
                pass
        try:
            os.remove(merged_bc)
            os.remove(merged_o)
        except OSError:
            pass
        if verbose:
            info('Hybrid executable: {}'.format(exe_name))
        return exe_name

    # Define custom compilation routines for OpenQASM and Q#
    # i.e. use custom tool to lower to LLVM IR -> LLVM assembler
    # To support mixing multiple file types in one compilation.
    # Util to compile QASM2/3 (MLIR)
    def compile_qasm(filename):
        
        global Qasmmap
        input_backend_extra = []
        input_backend = None

        if os.path.splitext(filename)[1] == '.py':
            if '-input-backend' in sys.argv[1:]:
                input_backend = sys.argv[sys.argv.index('-input-backend') + 1]
                sys.argv.remove(input_backend)
                sys.argv.remove('-input-backend')

                if input_backend == 'originir':
                    from pyqpanda3.intermediate_compiler import convert_originir_file_to_qprog,convert_qprog_to_qasm
                    qprog = convert_originir_file_to_qprog(filename)
                    originir_to_qasm = convert_qprog_to_qasm(qprog)
                elif input_backend not in {'qcis','qiskit'}:
                    print("Currently only support originir, qcis and qiskit")
                    print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                    exit(1)
                input_backend_extra = ['-input-backend', input_backend]
            else:
                print("Invalid compile command: Python file must provide input backend.\neg. -input-backend originir")
                print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                exit(1)

        llvm_bin_path = str(pathlib.Path(compiler).parent)
        # Run preprocessor to handle any includes
        result = ''
        if os.path.splitext(filename)[1] == '.qasm':
            result = subprocess.check_output(
                [compiler, '-x', 'c++', '-E', '-P', filename]).decode('ascii')
            has_no_entry_point_pragma = False
            if '#pragma' in result and 'no_entrypoint' in result:
                sys.argv.append('-no-entrypoint')
                has_no_entry_point_pragma = True
        elif input_backend == 'originir':
            result = originir_to_qasm
        elif input_backend == 'qcis':
            with open(filename, 'r') as f:
                result = f.read()
        elif input_backend == 'qiskit':
            with open(filename, 'r') as f:
                result = f.read()
            import tokenize
            import io
            tokens = []
            for tok in tokenize.generate_tokens(io.StringIO(result).readline):
                if tok.type != tokenize.COMMENT:
                    tokens.append(tok)
            result_ = tokenize.untokenize(tokens)
            lines = result_.splitlines()
            first_nonempty_line = None
            for line in lines:
                stripped = line.strip()
                if stripped:
                    first_nonempty_line = stripped
                    break
            if first_nonempty_line not in ('from qiskit import QuantumCircuit', 'from qiskit import *'):
                print("Error: only support from qiskit import QuantumCircuit or from qiskit import *")
                print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                exit(1)
            else:
                lines = result_.splitlines(keepends=True) 
                if lines:
                    result = ''.join(lines[1:]) 

            
        if os.path.splitext(filename)[1] == '.qasm' or input_backend == 'originir':
            if not check_qasm_header(result.split('\n')):
                print("QASM file does not have a valid header,Support OpenQASM 2.0")
                print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                exit(1)
            filter_lines = [line for line in result.split('\n')
                        if 'OPENQASM' not in line and len(line) > 0 and (not ('#pragma' in line and 'no_entrypoint' in line))]
            creg_count = sum(1 for line in filter_lines if "creg" in line)

            if creg_count == 1:
                for i,line_new in enumerate(filter_lines):
                    if "creg" in line_new and line_new[-3] == '1':
                        filter_lines[i] = line_new[:-3] + '2' + line_new[-2:]
                        break
        
        
            qreg_names = []
            for line in filter_lines:
                stripped_line = line.strip()
                if stripped_line.startswith('qreg '):
                    # handle multiple formats: qreg q[3]; qreg quantum_reg[5]; etc.
                    reg_part = stripped_line[5:].split(';')[0].strip()  # remove qreg and semicolon
                    if '[' in reg_part:
                        reg_name = reg_part.split('[')[0].strip()
                        qreg_names.append(reg_name)

            if Qasmmap:
                modified_lines = []
                barrier_added = False

                for line in filter_lines:
                # if the first measurement operation is found and no barrier is added
                    if not barrier_added and line.strip().startswith('measure'):
                        # add barrier to each quantum register
                        for qreg_name in qreg_names:
                            modified_lines.append(f'barrier {qreg_name};')
                        barrier_added = True

                    modified_lines.append(line)
                if not barrier_added:
                    modified_lines = filter_lines

                text = 'OPENQASM 2.0;\n' + \
                '\n'.join(modified_lines)
            else:
                text = 'OPENQASM 3;\n' + \
                '\n'.join(filter_lines)
        
            # process #pragma export; -> #pragma { export };
            if '#pragma' in text and 'export' in text:
                new_text = ''
                for line in text.split('\n'):
                    if '#pragma' in line and '{' not in line:
                        new_text += '#pragma { export; }\n'
                        continue
                    new_text+=line+'\n'
                text = new_text 
        else:
            text = result

        base_name = os.path.splitext(filename)[0].split(os.path.sep)[-1]
        # Write to a temporary file

        temp_file_name = '__tmp__'+base_name+'.qasm'
        with open(temp_file_name, 'w') as f:
            f.write(text)

        use_sabre_cpp = '-sabre-cpp' in sys.argv[1:]
        if use_sabre_cpp:
            sys.argv.remove('-sabre-cpp')
        if Qasmmap and input_backend != 'qcis':
            if not use_sabre_cpp:
                qiskit_map(temp_file_name)
            result = subprocess.check_output([compiler, '-x', 'c++', '-E', '-P', temp_file_name]).decode('ascii')
            text = 'OPENQASM 3;\n' + \
                '\n'.join([line for line in result.split('\n')
                           if 'OPENQASM' not in line and len(line) > 0 and (not ('#pragma' in line and 'no_entrypoint' in line))])
            with open(temp_file_name, 'w') as f:
                f.write(text)

        extra_args = ['-internal-func-name', base_name] + input_backend_extra
        if '-no-entrypoint' in sys.argv[1:]:
            sys.argv.remove('-no-entrypoint')
            extra_args.append('-no-entrypoint')
        
        # FIXME: define pass-management CLI options for qllvm driver
        if '--q-optimize' in sys.argv[1:]:
            sys.argv.remove('--q-optimize')
            extra_args.append('--q-optimize')
        # Parse clang -Ox optimization level:

        for arg in sys.argv[1:]:
            if re.match(r'^-O\d+$', arg):
                if arg not in {'-O0','-O1'}:
                    print('Not support optimization level:',arg)
                    print('Onlyr support optimization level: O0 or O1')
                    print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
                    exit(1)
                extra_args.append(arg)
        
        if len(accName):
            extra_args.append('-qpu')
            extra_args.append(accName)

        if len(qrtName):
            extra_args.append('-qrt')
            extra_args.append(qrtName)

        if len(placementName):
            extra_args.append('-placement')
            extra_args.append(placementName)

        if '-verbose-error' in sys.argv[1:]:
            extra_args.append('-verbose-error')
            sys.argv.remove('-verbose-error')

        if '-print-final-submission' in sys.argv[1:]:
            extra_args.append('-print-final-submission')

        # Some options that we want to pass on to mlir tool
        # (a subset of --help that we think is useful)
        mlir_forward_options = ['--pass-timing', '--print-ir-after-all', '--print-ir-after-change', '--print-ir-before-all']
        for mlir_forward_option in mlir_forward_options:
            if mlir_forward_option in sys.argv[1:]:
                # Forward to mlir tool
                extra_args.append(mlir_forward_option)
                # and remove from the main qllvm args
                sys.argv.remove(mlir_forward_option)
        if '-circuit-state' in sys.argv[1:]:
            extra_args.append('-circuit-state')
            sys.argv.remove('-circuit-state')

        if '-emitmlir' in sys.argv[1:]:
           extra_args.append('-emitmlir')
           sys.argv.remove('-emitmlir')
        if '-emitqir' in sys.argv[1:]:
           extra_args.append('-emitqir')
           sys.argv.remove('-emitqir')

        for a in sys.argv[1:]:
            if('-basicgate' in a):
                extra_args.append(a)
                sys.argv.remove(a)
                break

        if '-pass-count' in sys.argv[1:]:
            extra_args.append('-pass-count')
            sys.argv.remove('-pass-count')
        if '-syn-opt' in sys.argv[1:]:
            extra_args.append('-syn-opt')
            sys.argv.remove('-syn-opt')
        if '-pass-effect' in sys.argv[1:]:
            extra_args.append('-pass-effect')
            sys.argv.remove('-pass-effect')

        for a in sys.argv[1:]:
            if('-customPassSequence' in a):
                extra_args.append(a)
                sys.argv.remove(a)
                break

        if '-random_seq' in sys.argv[1:]:
            extra_args.append('-random_seq')
            sys.argv.remove('-random_seq')

        if Shots:
            extra_args.append('-shots')
            extra_args.append(Shots)
        # Backend code generation: -qpu <backend> triggers emit via BackendRegistry
        BACKEND_CONFIG = {
            'qasm-backend': {
                'emit_arg': '-emit-backend=qasm-backend',
                'output_suffix': '_compiled.qasm',
                'post_process': 'qasm',  # run modify_qasm
            },
            'qir-runner': {
                'emit_arg': '-emit-backend=qir-runner',
                'output_suffix': '.bc',
            },
            'tianyan': {
                'emit_arg': '-emit-backend=tianyan',
                'output_suffix': '_compiled.py',
            },
            'originquantum': {
                'emit_arg': '-emit-backend=originquantum',
                'output_suffix': '_compiled.py',
            }
        }
        backend_name = accName.split('[')[0] if '[' in accName else accName
        backend_name = backend_name.split(':')[0] if ':' in backend_name else backend_name
        use_backend_path = (backend_name in BACKEND_CONFIG)
        if use_backend_path:
            cfg = BACKEND_CONFIG[backend_name]
            extra_args.append(cfg['emit_arg'])
            extra_args.append('-output-path=' + base_name + cfg['output_suffix'])
            if use_sabre_cpp and Qasmmap and connectivity_initial:
                sabre_edges = ';'.join(f"{e[0]},{e[1]}" for e in connectivity_initial)
                extra_args.append('-sabre-coupling-map=' + sabre_edges)

        # Operate on the temporary file
        # print(f"compile qasm extra_args:  {extra_args}")
        # print("start to compile")
        result = subprocess.run(
                ['@CMAKE_INSTALL_PREFIX@/bin/qllvm-compile', temp_file_name] + extra_args, check=True)
        # print("finish compile")
        if use_backend_path:
            os.remove(temp_file_name)
            output_path = base_name + BACKEND_CONFIG[backend_name]['output_suffix']
            if BACKEND_CONFIG[backend_name].get('post_process') == 'qasm':
                modify_qasm(output_path)

            if 'originquantum' in  accName:

                from pyqpanda3.intermediate_compiler import convert_originir_file_to_qprog, convert_originir_string_to_qprog
                from pyqpanda3.qcloud.qcloud import ChipBackend
                from pyqpanda3.qcloud import QCloudService, LogOutput, QCloudOptions
                from pyqpanda3.transpilation import Transpiler
                from pyqpanda3.core import QProg, GateType, RPHI,U3
                import numpy as np

                api_key = "b39c7065b7992add6929d9bc88e72613154112b4006333fb9c73e37784552ae568527a73645039687961386e67757a37" # Replace with your own key
                
                prog_1 = convert_originir_file_to_qprog(output_path)

                rz_angles = [0]*prog_1.qubits_num()
                rphi_cz_prog = QProg()
                measure_nodes = prog_1.get_measure_nodes()
                for gate in prog_1.gate_operations():
                    if gate.gate_type() == GateType.RZ:
                        rz_angles[gate.qubits()[0]] -= gate.parameters()[0]
                    elif gate.gate_type() == GateType.BARRIER:
                        rphi_cz_prog << gate
                    elif gate.gate_type() == GateType.CZ:
                        rphi_cz_prog << gate
                    elif gate.gate_type() == GateType.RPHI:
                        rphi_cz_prog << gate
                    else:
                        raise ValueError("NOT SUPPORT GATE TYPE!!!!")
                for nodes in measure_nodes:
                    rphi_cz_prog << nodes

                    # Obtain the service
                service = QCloudService(api_key)
                backend_wukong = service.backend("180")
                chip_info = backend_wukong.chip_info()
                backend: ChipBackend = chip_info.get_chip_backend()
            
                # Convert to chip instruction
                use_pattern = False
                ins = rphi_cz_prog.to_instruction(backend, 1, use_pattern)

                output_path_temp = f"{base_name}_compiled.json"
                with open(output_path_temp, 'w') as file:
                    file.write(ins)

                os.system(f"rm {output_path}")
                output_path = output_path_temp
            

            if '-o' in sys.argv[1:]:
                fidx = sys.argv.index('-o')
                output_file = sys.argv[fidx+1]
                qasm_name_temp = filename.rsplit('/')[-1]
                exe_folder = output_file.rsplit('/', 1)[0]
                qasm_name = qasm_name_temp.rsplit('.', 1)[0]
                exe_name = output_file.split('/')[-1]

                if 'qasm-backend' in accName:
                    if '/' in output_file:
                        os.system(f" mv {output_path} {exe_folder}/{exe_name}.qasm")
                        output_path = f"{exe_folder}/{exe_name}.qasm"
                    else:
                        current_dir = os.getcwd()
                        os.system(f"cd {current_dir} && mv {output_path} {exe_name}.qasm")
                elif 'qir-runner' in accName:
                    dest_bc = output_file if output_file.endswith('.bc') else output_file + '.bc'
                    os.system(f" mv {output_path} {dest_bc}")
                    output_path = dest_bc
                elif 'tianyan' in  accName:
                    if '/' in output_file:
                        os.system(f" mv {output_path} {exe_folder}/{exe_name}.py")
                    else:
                        current_dir = os.getcwd()
                        os.system(f"cd {current_dir} && mv {output_path} {exe_name}.py")
                elif 'originquantum' in  accName:
                    if '/' in output_file:
                        os.system(f" mv {output_path} {exe_folder}/{exe_name}.py")
                        # os.system(f" mv {output_path} {exe_folder}/{exe_name}.json")
                    else:
                        current_dir = os.getcwd()
                        os.system(f"cd {current_dir} && mv {output_path} {exe_name}.py")   
                        # os.system(f"cd {current_dir} && mv {output_path} {exe_name}.json")   
            exit(0)

    # Phase 1: Detect hybrid compilation (classical C++/CUDA + quantum QASM)
    cpp_files = [arg for arg in sys.argv[1:] if os.path.isfile(arg) and os.path.splitext(arg)[1] in ['.cpp', '.cc', '.cxx']]
    cu_files = [arg for arg in sys.argv[1:] if os.path.isfile(arg) and os.path.splitext(arg)[1] == '.cu']
    qasm_files = [arg for arg in sys.argv[1:] if os.path.isfile(arg) and os.path.splitext(arg)[1] == '.qasm']

    if (cpp_files or cu_files) and qasm_files:
        output_exe = 'hybrid_app'
        if '-o' in sys.argv[1:]:
            idx = sys.argv.index('-o')
            output_exe = sys.argv[idx + 1]
            sys.argv.remove(output_exe)
            sys.argv.remove('-o')
        try:
            if cu_files:
                compile_hybrid_cuda_quantum(cpp_files, cu_files, qasm_files, output_exe)
            # Default hybrid (C++ + QASM): qir-runner subprocess, or LLVM link with qir-qrt-stub (see compile_hybrid).
            elif accName in ('qir-runner', 'qpp'):
                compile_hybrid_qir_runner(cpp_files, qasm_files, output_exe)
            else:
                compile_hybrid(cpp_files, qasm_files, output_exe)
        except subprocess.CalledProcessError as e:
            if verbose:
                print(e)
            exit(e.returncode if hasattr(e, 'returncode') else 1)
        except Exception as e:
            print(bcolors.FAIL + '[qllvm] Hybrid compile failed: ' + str(e) + bcolors.ENDC, file=sys.stderr)
            if verbose or '-v' in sys.argv:
                import traceback
                traceback.print_exc()
            exit(1)
        exit(0)

    for arg in sys.argv[1:]:
        if os.path.isfile(arg) and mimetypes.guess_type(arg)[0] is not None:
            filename = arg
            fileType = mimetypes.guess_type(filename)[0]
            if fileType == 'text/x-c++src':
                if OPENQASM_ONLY_BUILD:
                    print(bcolors.FAIL + '[qllvm] C++ compilation is not supported in OpenQASM-only build. Use .qasm or .py (OpenQASM) input files.' + bcolors.ENDC)
                    exit(1)
                break
        if os.path.isfile(arg) and (os.path.splitext(arg)[1] == '.qasm' or os.path.splitext(arg)[1] == '.py'):
            fileType = 'openqasm'
            filename = arg
            # ZHUYU_202504_BEGIN
            if '-kernel' in sys.argv[1:]:
                sidx = sys.argv.index('-kernel')
                kernelName = sys.argv[sidx+1]
                sys.argv.remove('-kernel')
                sys.argv.remove(kernelName)
                if kernelName in ['qft','qpe','dj','ghz','wstate','phase_code','bit_code']:
                    kernelSize = '100'
                    backendTopology = 'line'
                    if '-kernel-size' in sys.argv[1:]:
                        sidx = sys.argv.index('-kernel-size')
                        kernelSize = sys.argv[sidx+1]
                        sys.argv.remove('-kernel-size')
                        sys.argv.remove(kernelSize)
                    if '-backend-topology' in sys.argv[1:]:
                        sidx = sys.argv.index('-backend-topology')
                        backendTopology = sys.argv[sidx+1]
                        sys.argv.remove('-backend-topology')
                        sys.argv.remove(backendTopology)
                        if backendTopology not in ['grid','line']:
                            print('unsupported backend topology\n')
                            backendTopology =  'line'
                    kernel_containning_folder = 'mapped_1d_qasm3/'
                    if backendTopology == 'grid':
                        kernel_containning_folder ='mapped_2d_qasm3/'
                    sidx = sys.argv.index(filename)
                    import shutil
                    kernel_filename = '@CMAKE_INSTALL_PREFIX@/kernel_optimized/'+ kernel_containning_folder + kernelName + '/' + kernelName + '.qasm'
                    temp_kernel_filename = '@CMAKE_INSTALL_PREFIX@/kernel_optimized/'+ kernel_containning_folder + kernelName + '/' + kernelName + '_' + kernelSize + '.qasm'
                    shutil.copy(kernel_filename,temp_kernel_filename)
                    with open(temp_kernel_filename,'a') as file:
                        file.write('const nc = '+kernelSize+';\nqubit q1[nc];\n'+kernelName+'(nc) q1;\n')

                    filename = temp_kernel_filename 
                    sys.argv[sidx] = filename
                else:
                    print("unsupported kernel")
            
            compile_qasm(filename)
        
       
    return 0

if __name__ == "__main__":
    r = 0
    try:
        r = main()
        sys.exit(r)
    except Exception as e:
        if r != 0 or e != None:
            print(bcolors.BOLD+bcolors.FAIL+'[qllvm] fatal error.'+bcolors.ENDC)
            print(f"error file: {sys.argv}")
            if fatal_error_verbose:
                print(e)
