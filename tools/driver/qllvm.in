#!/usr/bin/env python3
# OpenQASM-only build (no C++/QJIT)
OPENQASM_ONLY_BUILD = True


import argparse, sys, os, glob, subprocess, mimetypes, re, pathlib,time

class bcolors:
    HEADER = '\033[95m'
    OKBLUE = '\033[94m'
    OKCYAN = '\033[96m'
    OKGREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'

def info(msg):
    print('{}[qllvm]{} {}{}'.format(bcolors.BOLD+bcolors.OKBLUE,
                                    bcolors.ENDC+bcolors.BOLD, msg, bcolors.ENDC))

def modify_qasm(file_path):
    # read QASM file content
    with open(file_path, 'r') as file:
        qasm_str = file.read()
    # print(qasm_str)
    # 1. get the number of measurement gates
    lines = qasm_str.split('\n')
    qr_match = re.search(r'(?:qreg|qubit)\s+([a-zA-Z_][\w]*)\s*\[([0-9]+)\];', qasm_str)
    cr_match = re.search(r'creg\s+([a-zA-Z_][\w]*)\s*\[([0-9]+)\];', qasm_str)
    if not qr_match or not cr_match:
        raise ValueError("QASM file not found qreg/qubit or creg definition")
    qr_name = qr_match.group(1)
    cr_name = cr_match.group(1)

    measure_count = sum(1 for line in lines if 'measure' in line)
    # 2. modify the lines containing creg
    new_lines = []
    for line in lines:
        if 'creg' in line:
            # modify the number of classical registers
            new_line = f"creg {cr_name}[{measure_count}];"
            new_lines.append(new_line)
        else:
            new_lines.append(line)

    # 3. increment the number of classical registers for each measurement gate
    creg_index = 0
    for i, line in enumerate(new_lines):
        measure_match = re.match(rf'measure\s+{qr_name}\[(\d+)\]\s*->\s*{cr_name}\[\d+\];', line.strip())
        if measure_match:
            qubit_index = measure_match.group(1)
            new_lines[i] = f"measure {qr_name}[{qubit_index}] -> {cr_name}[{creg_index}];"
            creg_index += 1
    # 4. write the modified content back to the file
    with open(file_path, 'w') as file:
        file.write('\n'.join(new_lines))

def qiskit_map(filename):
    global initial_map
    global connectivity_initial
    
    from qiskit import QuantumCircuit,transpile
    from qiskit.transpiler import CouplingMap, Layout
    from qiskit.transpiler.passes import SetLayout,SabreLayout,SabreSwap,FullAncillaAllocation, EnlargeWithAncilla, ApplyLayout, LookaheadSwap
    from qiskit.transpiler import PassManager
    from qiskit.qasm2 import dumps

    with open(filename,"r")as file:
        qasm_str = file.read()

    qc_t = QuantumCircuit.from_qasm_str(qasm_str)
    qc = transpile(qc_t,basis_gates=['rx', 'ry', 'rz', 'cz','h',"cx","x","s","t","tdg","sdg"],optimization_level=0)

    # if len(data_list) < len(qc.qubits):
    #     print("initial map error")
    #     exit(0)
    # print(connectivity_initial)

    edges_set = set()
    for edge in connectivity_initial:
        if not edge or len(edge) < 2:
            continue
        if edge[0] == edge[1]:
            continue
        sorted_edge = tuple(sorted(edge))
        edges_set.add(sorted_edge)

    edges = list(sorted(edges_set))
    connectivity = CouplingMap(edges)

    graph = {i: set() for i in range(connectivity.size())}
    for a, b in edges:
        graph.setdefault(a, set()).add(b)
        graph.setdefault(b, set()).add(a)

    def connected_subset(start, size):
        visited = []
        queue = [start]
        seen = set()
        while queue and len(visited) < size:
            node = queue.pop(0)
            if node in seen:
                continue
            seen.add(node)
            visited.append(node)
            queue.extend(sorted(graph.get(node, [])))
        return visited

    components = []
    seen = set()
    for node in graph:
        if node in seen:
            continue
        stack = [node]
        comp = set()
        while stack:
            cur = stack.pop()
            if cur in seen:
                continue
            seen.add(cur)
            comp.add(cur)
            stack.extend(graph.get(cur, []))
        components.append(comp)

    if not components:
        raise RuntimeError("Coupling map has no connected components")

    largest = max(components, key=len)
    if len(largest) < len(qc.qubits):
        raise RuntimeError(
            f"Coupling map largest component size {len(largest)} is smaller than circuit qubits {len(qc.qubits)}")

    start_node = min(largest)
    allowed = connected_subset(start_node, len(qc.qubits))
    if len(allowed) < len(qc.qubits):
        raise RuntimeError("Failed to select a connected subset for layout")

    if initial_map == "":
        edges = [e for e in edges if e[0] in allowed and e[1] in allowed]
        connectivity = CouplingMap(edges)
        max_allowed = max(allowed) if allowed else -1
        while connectivity.size() < max_allowed + 1:
            connectivity.add_physical_qubit(connectivity.size())

        layout_dict = {qc.qubits[i]: allowed[i] for i in range(len(qc.qubits))}
        set_layout = SetLayout(Layout(layout_dict))
    else:
        data_list = eval(initial_map)
        layout_dict = {}
        for i in range(len(qc.qubits)):
            layout_dict[qc.qubits[i]] = data_list[i]

        layout = Layout(layout_dict)
        set_layout = SetLayout(layout)

    full_ancilla = FullAncillaAllocation(connectivity)
    enlarge_ancilla = EnlargeWithAncilla()
    apply_layout = ApplyLayout()

    sabre_swap = SabreSwap(coupling_map=connectivity, heuristic="lookahead",   seed=42)
    # lookahead_swap = LookaheadSwap(coupling_map=connectivity)

    pm = PassManager([set_layout,
        full_ancilla,
        enlarge_ancilla,
        apply_layout,
        sabre_swap])
            # lookahead_swap])

    result = pm.run(qc)
    qasm_str = dumps(result)

    with open(filename,"w")as file:
        file.write(qasm_str)

    
def check_qasm_header(file):

    "check the qasm header "
    non_empty_lines = []
    for line in file:
        comment_pos = line.find('//')
        if comment_pos != -1:
            line = line[:comment_pos]
        stripped = line.strip()
        if stripped:                     
            non_empty_lines.append(stripped)
        
    
    if len(non_empty_lines) >= 2 and (non_empty_lines[0] == 'OPENQASM 2.0;' or non_empty_lines[0] == 'OPENQASM 3;') and non_empty_lines[1] == 'include "qelib1.inc";':
        return True

    return False


