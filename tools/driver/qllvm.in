        sHandlerArgs += ['-Xclang', '-plugin-arg-qllvm-args', '-Xclang', '-shots', '-Xclang', '-plugin-arg-qllvm-args', '-Xclang', Shots]

    # Optimization level for flattened (runtime) kernel
    # Default: 0 (no optimization)
    qrtOptLevel = 0
